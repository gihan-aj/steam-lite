  "db_name": "SQLite",
  "query": "\n                SELECT\n                    app_id,\n                    name,\n                    review_score,\n                    total_reviews,\n                    is_indie as \"is_indie: bool\",\n                    price_current,\n                    price_original,\n                    platform_windows as \"platform_windows: bool\",\n                    tags,\n                    last_updated as \"last_updated: chrono::DateTime<chrono::Utc>\",\n                    gem_score, \n                    owners_lower, \n                    avg_playtime,\n                    crawl_source, \n                    header_image, \n                    short_desc, \n                    genres,\n                    last_price_check as \"last_price_check: chrono::DateTime<chrono::Utc>\"\n                FROM games\n                WHERE review_score >= ?\n                AND is_indie = 0\n                AND platform_windows = 1\n                ORDER BY review_score DESC\n                LIMIT ?\n                ",
