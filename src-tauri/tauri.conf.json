{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "steam-lite",
  "version": "0.1.2",
  "identifier": "com.gihan.steam-lite",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Steam Lite",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "backgroundColor": "#0e0f13"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU2QTI3NTY0RkFBQzk3QkMKUldTOGw2ejZaSFdpVnFRYnFsRmNSNXFPWXVLQ3hOeFl3RjlmUEtudktCODZrS1FpYVpISFYzeTcK",
      "endpoints": [
        "https://github.com/gihan-aj/steam-lite/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  }
}
